    "def clean_text(text):\n",
    "    if not isinstance(text, str):\n",
    "        return \"\"\n",
    "    text = re.sub(r'http\\S+|www\\S+', '', text)\n",
    "    text = re.sub(r'[^a-zA-Z0-9\\s.,!?\\'\"\\-]', '', text)\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()\n",
    "    return text.lower()\n",
    "\n",
    "df_filtered['headline']          = df_filtered['headline'].apply(clean_text)\n",
    "df_filtered['short_description'] = df_filtered['short_description'].apply(clean_text)\n",
    "df_filtered['text']              = df_filtered['headline'] + ' ' + df_filtered['short_description']\n",
    "\n",
    "df_filtered.dropna(subset=['text'], inplace=True)\n",
    "df_filtered = df_filtered[df_filtered['text'].str.strip() != ''].reset_index(drop=True)\n",
    "\n",
    "le = LabelEncoder()\n",
    "df_filtered['label'] = le.fit_transform(df_filtered['category'])\n",
    "\n",
    "label2cat  = dict(enumerate(le.classes_))\n",
    "NUM_LABELS = len(le.classes_)\n",
    "\n",
    "print(\"Label mapping:\", label2cat)\n",
    "print(f\"Total samples after cleaning: {len(df_filtered)}\")"
   ]
  },
