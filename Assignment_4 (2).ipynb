    "TOP_N_CATEGORIES  = 6\n",
    "SAMPLES_PER_CLASS = 500\n",
    "\n",
    "top_categories = df['category'].value_counts().head(TOP_N_CATEGORIES).index.tolist()\n",
    "df_filtered = df[df['category'].isin(top_categories)].copy()\n",
    "\n",
    "df_filtered = (\n",
    "    df_filtered\n",
    "    .groupby('category', group_keys=False)\n",
    "    .apply(lambda x: x.sample(n=min(SAMPLES_PER_CLASS, len(x)), random_state=42))\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "print(f\"Filtered dataset shape: {df_filtered.shape}\")\n",
    "print(df_filtered['category'].value_counts())"
   ]
